# Backend Environment
# -------------------
# DATABASE_URL: The connection string for the database (e.g., PostgreSQL for deployment).
DATABASE_URL=postgresql://user:password@host:port/dbname

# MOCK_LLM_PROVIDER: Forces deterministic canonical demo mode. 
# 1 = Deterministic Mode (Use for Portfolio Demo). 0 = Live Provider Mode.
MOCK_LLM_PROVIDER=1

# CORS_ORIGINS: Comma-separated list of allowed frontend URLs. Use * for development or the specific Vercel URL for production.
CORS_ORIGINS=*

# (Optional) GEMINI_API_KEY: Only required if MOCK_LLM_PROVIDER=0. Do not use for the stable portfolio demo.
# GEMINI_API_KEY=your_real_key_here

# Frontend Environment
# --------------------
# NEXT_PUBLIC_API_URL: The public URL of the deployed backend.
NEXT_PUBLIC_API_URL=https://your-backend-url.onrender.com
